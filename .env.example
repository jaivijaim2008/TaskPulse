[TEMPLATE]
# ============================================
# Gemini API Keys (Multi-Key Rotation)
# ============================================
# TaskPulse supports up to 10 Gemini API keys for automatic rotation.
# When one key hits quota, the server switches to the next.
# Create keys from different accounts at: https://aistudio.google.com/apikey
# Minimum: Set GEMINI_API_KEY. Recommended: Add GEMINI_API_KEY1-4.

GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_API_KEY1="MY_GEMINI_API_KEY"
GEMINI_API_KEY2="MY_GEMINI_API_KEY"
GEMINI_API_KEY3="MY_GEMINI_API_KEY"
GEMINI_API_KEY4="MY_GEMINI_API_KEY"

# ============================================
# App Configuration
# ============================================
APP_URL="MY_APP_URL"
